{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LoreGUI",
  "version": "0.1.0",
  "identifier": "games.braindead.loregui",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm --prefix ../frontend run dev",
    "beforeBuildCommand": "npm --prefix ../frontend run build"
  },
  "app": {
    "windows": [
      {
        "title": "LoreGUI",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/BiloxiStudios/loregui/releases/download/nightly/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      },
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE3MzQ1NTZFRjUzMDgxQTQKUldTa2dURDFibFUwcDBMM1ZPNTEvSjk1ZFJkMVJpTFhTM3dWUVJaYld2U1NjdktyVE9OVUw5dFgK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "externalBin": ["binaries/loreserver"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
